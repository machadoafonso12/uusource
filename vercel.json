{
  "version": 2,
  "builds": [
    { "src": "api/search.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/brands", "dest": "/brands.html" },
    { "src": "/coupons", "dest": "/coupons.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
